# ─────────────────────────────────────────────────────────────────────────────
# Naval Strike — Datacenter reverse proxy config (Nginx)
#
# Replace:
#   naval-strike.example.com  →  your actual domain
#   ALPINE_IP                 →  your Alpine server's IP
#
# This config assumes Certbot / Let's Encrypt for SSL.
# ─────────────────────────────────────────────────────────────────────────────

upstream naval_frontend {
    server ALPINE_IP:8080;
}

upstream naval_ws {
    server ALPINE_IP:3001;
}

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    listen 80;
    server_name naval-strike.example.com;
    return 301 https://$host$request_uri;
}

# ── HTTPS ─────────────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name naval-strike.example.com;

    ssl_certificate     /etc/letsencrypt/live/naval-strike.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/naval-strike.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    # ── Frontend ──────────────────────────────────────────────────────────────
    location / {
        proxy_pass         http://naval_frontend;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # ── WebSocket relay (/ws → Alpine:3001) ───────────────────────────────────
    location /ws {
        proxy_pass         http://naval_ws;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "Upgrade";
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_read_timeout 86400s;   # keep WS connections alive
        proxy_send_timeout 86400s;
    }
}
